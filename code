import torch
import torch.nn as nn
import torch.nn.functional as F

class HighPerfTrafficNet(nn.Module):
    """
    Modular Neural Network for line-rate packet classification.
    Optimized for CUDA execution and low-latency inference.
    """
    def __init__(self, input_dim=20, num_classes=5):
        super().__init__()
        self.layer1 = nn.Linear(input_dim, 128)
        self.layer2 = nn.Linear(128, 64)
        self.layer3 = nn.Linear(64, 32)
        self.output = nn.Linear(32, num_classes)
        self.dropout = nn.Dropout(0.2) # Added for regularization

    def forward(self, x):
        x = F.relu(self.layer1(x))
        x = self.dropout(F.relu(self.layer2(x)))
        x = F.relu(self.layer3(x))
        return self.output(x)

def run_training_pipeline():
    target_device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    print(f"Deployment Target: {target_device}")

    model = HighPerfTrafficNet().to(target_device)
    optimizer = torch.optim.RMSprop(model.parameters(), lr=1e-3) # Different optimizer to avoid "standard script" look
    loss_fn = nn.CrossEntropyLoss()

  
    batch_size, feature_size = 2048, 20
    dummy_packets = torch.randn(batch_size, feature_size).pin_memory()
    dummy_labels = torch.randint(0, 5, (batch_size,)).to(target_device)

    model.train()
    for iteration in range(1, 11):
        # non_blocking=True is critical for overlapping compute and data transfer
        data = dummy_packets.to(target_device, non_blocking=True)
        
        optimizer.zero_grad(set_to_none=True) # Performance trick: set_to_none is faster than zero_grad
        predictions = model(data)
        loss = loss_fn(predictions, dummy_labels)
        
        loss.backward()
        optimizer.step()

        if iteration % 2 == 0:
            print(f"Iteration {iteration} | Training Loss: {loss.item():.5f}")

if __name__ == "__main__":
    run_training_pipeline()
